# ── Clerk auth (existing) ─────────────────────────────────────────
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
CLERK_JWKS_URL=https://your-clerk-domain/.well-known/jwks.json

# ── OpenAI (upstream chat + embeddings) ───────────────────────────
OPENAI_API_KEY=sk-...

# ── LLM gateway (Task 2 requirement) — Helicone (simplest) ────────
# Set HELICONE_API_KEY and you're done: chat + embeddings route through
# the Helicone proxy automatically (base URL + auth header are handled in
# code), billed to your OpenAI account, logged in the Helicone dashboard.
# No Helicone credits needed. This also covers the "monitoring" component.
HELICONE_API_KEY=sk-helicone-...
LLM_CHAT_MODEL=gpt-5-nano
# Reasoning effort for gpt-5 models. "minimal"/"low" are much faster. Set "" to
# omit the parameter entirely (for models that don't support it).
LLM_REASONING_EFFORT=minimal

# ── Local dev: call FastAPI directly, bypassing Next's dev proxy ──
# Set this in .env.local so long agent requests don't get dropped by the
# Next dev proxy. Leave UNSET in production (Vercel routes /api itself).
NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:8000

# --- Alternative gateways (leave unset if using Helicone) ----------
# OpenRouter example (needs OpenRouter credits, uses "openai/gpt-5-nano"):
# LLM_GATEWAY_BASE_URL=https://openrouter.ai/api/v1
# LLM_GATEWAY_API_KEY=sk-or-...
# LLM_GATEWAY_HEADERS={"x-custom":"value"}   # optional extra headers as JSON
# EMBED_GATEWAY_BASE_URL=                    # optional separate embeddings gateway

# ── Embeddings ────────────────────────────────────────────────────
EMBED_MODEL=text-embedding-3-small
EMBED_DIM=1536

# ── Qdrant Cloud (vector database for RAG) ────────────────────────
QDRANT_URL=https://xxxxxxxx.cloud.qdrant.io:6333
QDRANT_API_KEY=...
QDRANT_COLLECTION=pm_prd_faq

# ── Tavily (public web search tool) ───────────────────────────────
TAVILY_API_KEY=tvly-...
